{
  "name": "ball-radar-backend",
  "version": "1.0.0",
  "description": "Ball Radar — Sydney basketball court sharing platform (backend)",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/seed.ts",
    "migrate:en": "tsx src/migrate-en.ts",
    "import:courts": "tsx src/import-courts.ts",
    "import:osm": "tsx src/import-osm.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@sentry/node": "^8.30.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.14",
    "pg": "^8.13.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "tsx": "^4.19.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.0",
    "@types/nodemailer": "^6.4.16",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "embedded-postgres": "^18.4.0-beta.17",
    "supertest": "^7.0.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
