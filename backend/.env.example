# Copy to .env and adjust (only needed for bare-metal runs; Docker/Railway use their own variables)

# Server port (Railway injects PORT automatically)
PORT=4000

# Postgres connection string
DATABASE_URL=postgres://hoop:hoop@localhost:5432/ballradar
# Set to true for an external/public Postgres that requires TLS (keep false for Railway internal networking)
DATABASE_SSL=false

# Uploads directory (point at a mounted persistent volume on Railway, e.g. /app/uploads)
# UPLOADS_DIR=/app/uploads

# JWT signing secret (use a long random string in production)
JWT_SECRET=ballradar-dev-secret-change-me

# Admin accounts: comma-separated emails auto-promoted to admin on boot.
# Sign up/log in with this email, then open /admin.
ADMIN_EMAILS=

# Observability (optional)
SENTRY_DSN=
LOG_LEVEL=info

# CORS: leave empty to allow all origins. To lock down, set your frontend URL(s),
# comma-separated, e.g. https://ball-radar-frontend.up.railway.app
CORS_ORIGIN=

# Email mode: dev = code printed in the log and returned by the API; smtp = real send
EMAIL_MODE=dev

# --- Email (only when EMAIL_MODE=smtp) ---
# Preferred on cloud hosts like Railway: Resend's HTTP API (port 443, never blocked).
RESEND_API_KEY=
MAIL_FROM=Ball Radar <onboarding@resend.dev>
# Generic SMTP fallback, used only if RESEND_API_KEY is unset (example: a Gmail app password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# Google Places API key — only needed to run the court importer (npm run import:courts).
# Use a key with the Places API enabled and NO HTTP-referrer restriction (server-side
# calls have no referrer). Falls back to VITE_GOOGLE_MAPS_API_KEY if this is unset.
GOOGLE_MAPS_API_KEY=
