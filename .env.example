# Root config used by docker-compose. Copy to .env and fill in.
# docker compose reads this file automatically for variable substitution.

# Google Maps JavaScript API key (frontend map; required or the map won't show)
VITE_GOOGLE_MAPS_API_KEY=

# Backend
JWT_SECRET=ballradar-dev-secret-change-me
EMAIL_MODE=dev

# For real email (EMAIL_MODE=smtp), fill these and uncomment the matching lines in docker-compose.yml
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# MAIL_FROM=Ball Radar <your@gmail.com>
