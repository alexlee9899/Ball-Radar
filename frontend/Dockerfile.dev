# Ball Radar frontend — DEV image (used by docker-compose for hot reload).
FROM node:22-bookworm-slim

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

EXPOSE 5173

# Vite dev server with hot reload; proxies /api + /uploads to the backend.
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
