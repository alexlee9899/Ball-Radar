# Copy to .env and fill in your own values

# Google Maps JavaScript API key (required, or the map won't show)
VITE_GOOGLE_MAPS_API_KEY=

# Backend API base URL.
# - Local dev / single-service: leave EMPTY (Vite proxies /api and /uploads to the backend).
# - Separate frontend & backend services (e.g. Railway): set to the backend's public URL,
#   e.g. https://ball-radar-backend.up.railway.app  (no trailing slash)
VITE_API_BASE_URL=
